PROJECT_NAME           = "VisualStruct"
PROJECT_BRIEF          = "Visualizador de estructuras secuenciales y grafos en C con Raylib"
OUTPUT_DIRECTORY       = docs/doxygen
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = Spanish
USE_MDFILE_AS_MAINPAGE = README.md
MARKDOWN_SUPPORT       = YES
OPTIMIZE_OUTPUT_FOR_C  = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = NO
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
INLINE_INHERITED_MEMB  = NO
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_XML           = NO
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
INPUT                  = include src README.md docs
FILE_PATTERNS          = *.h *.c *.md
RECURSIVE              = YES
EXCLUDE                = src/legacy
